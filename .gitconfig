[alias]
    st=status
    recent=for-each-ref --count=10 --sort=-committerdate 'refs/heads/' --format '%(committerdate:relative), %(refname:short)'
[init]
    defaultBranch = master
[pull]
    rebase = true

# https://blog.gitbutler.com/how-git-core-devs-configure-git/
[branch]
    sort = -committerdate
[tag]
    sort = version:refname
[diff]
    algorithm = histogram
    colorMoved = plain
    mnemonicPrefix = true
    renames = true
[commit]
    verbose = true
[rerere]
    enabled = false
[merge]
    conflictstyle = diff3 
